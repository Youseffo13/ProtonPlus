msgstr "Configura il comportamento di traduzione da Direct3D 12 a Vulkan"

#: src/widgets/games/launch-options-editor/groups/vkd3d-options-group.vala:26
#: src/widgets/games/launch-options-editor/launch-options-editor-vkd3d-log-level.vala:21
msgid "VKD3D Logging Level"
msgstr "Livello di logging VKD3D"

#: src/widgets/games/launch-options-editor/groups/vkd3d-options-group.vala:29
msgid "Enable VKD3D GPUVA"
msgstr "Abilita GPUVA VKD3D"

#: src/widgets/games/launch-options-editor/groups/vkd3d-options-group.vala:30
msgid ""
"Enables GPU Virtual Addressing. Aligns Vulkan memory management with native "
"DX12 behavior to improve texture streaming and stability in open-world "
"games."
msgstr ""
"Abilita l'indirizzamento virtuale GPU. Allinea la gestione della memoria "
"Vulkan con il comportamento nativo DX12 per migliorare lo streaming delle "
"texture e la stabilità nei giochi open-world."

#: src/widgets/games/launch-options-editor/groups/vkd3d-options-group.vala:34
msgid "Enable VKD3D Shader Cache"
msgstr "Abilita cache shader VKD3D"

#: src/widgets/games/launch-options-editor/groups/vkd3d-options-group.vala:35
msgid ""
"Enables VKD3D's internal shader caching mechanism to minimize in-game "
"stutter."
msgstr ""
"Abilita il meccanismo di caching interno degli shader di VKD3D per "
"minimizzare i rallentamenti in-game."

