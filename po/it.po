#: src/widgets/games/games-shortcut-button.vala:39
msgid ""
"ProtonPlus was unable to add the shortcut to Steam. Please ensure Steam is "
"closed and try again."
msgstr ""
"ProtonPlus non è riuscito ad aggiungere il collegamento a Steam. Assicurati "
"che Steam sia chiuso e riprova."

#: src/widgets/games/games-tool-row.vala:18
#: src/widgets/tools/tools-migrate-box.vala:18
msgid "New tool"
msgstr "Nuovo strumento"

#: src/widgets/games/launch-options-editor/groups/advanced-options-group.vala:14
msgid "Advanced options"
msgstr "Opzioni avanzate"

#: src/widgets/games/launch-options-editor/groups/advanced-options-group.vala:15
msgid "Extra control over the final Steam launch command."
msgstr "Controllo extra sul comando di lancio finale di Steam."

#: src/widgets/games/launch-options-editor/groups/advanced-options-group.vala:17
msgid "Appends Steam's game command."
msgstr "Aggiunge in coda il comando di gioco di Steam."

#: src/widgets/games/launch-options-editor/groups/advanced-options-group.vala:19
msgid "Additional arguments"
msgstr "Argomenti aggiuntivi"

#: src/widgets/games/launch-options-editor/groups/advanced-options-group.vala:19
msgid "Add extra launch options"
msgstr "Aggiungi opzioni di lancio extra"

#: src/widgets/games/launch-options-editor/groups/advanced-options-group.vala:24
msgid "Custom launch arguments"
msgstr "Argomenti di lancio personalizzati"

#: src/widgets/games/launch-options-editor/groups/advanced-options-group.vala:24
msgid "Add your own launch options."
msgstr "Aggiungi le tue opzioni di lancio."

#: src/widgets/games/launch-options-editor/groups/audio-options-group.vala:14
msgid "Audio options"
msgstr "Opzioni audio"

#: src/widgets/games/launch-options-editor/groups/audio-options-group.vala:15
msgid "Audio-related launch options."
msgstr "Opzioni di lancio relative all'audio."

#: src/widgets/games/launch-options-editor/groups/audio-options-group.vala:18
msgid "PulseAudio low latency"
msgstr "PulseAudio bassa latenza"

#: src/widgets/games/launch-options-editor/groups/audio-options-group.vala:19
msgid ""
"Enables low latency mode in PulseAudio which can reduce audio latency in "
"some games (60, 90, 120)."
msgstr ""
"Abilita la modalità a bassa latenza in PulseAudio, che può ridurre la "
"latenza audio in alcuni giochi (60, 90, 120)."

#: src/widgets/games/launch-options-editor/groups/audio-options-group.vala:20
msgid "MSEC"
msgstr "MSEC"

#: src/widgets/games/launch-options-editor/groups/audio-options-group.vala:27
#: src/widgets/games/launch-options-editor/launch-options-editor-aco-debug.vala:11
#: src/widgets/games/launch-options-editor/launch-options-editor-dll-overrides.vala:36
#: src/widgets/games/launch-options-editor/launch-options-editor-radv-debug.vala:11
#: src/widgets/games/launch-options-editor/launch-options-editor-radv-perf-test.vala:11
#: src/widgets/games/launch-options-editor/launch-options-editor-vkd3d-config.vala:26
msgid "Disabled"
msgstr "Disabilitato"

#: src/widgets/games/launch-options-editor/groups/audio-options-group.vala:38
msgid "WINEALSA Channels"
msgstr "Canali WINEALSA"

#: src/widgets/games/launch-options-editor/groups/audio-options-group.vala:39
msgid ""
"Sets the number of ALSA output channels used by Wine. Available from GE-"
"Proton11-1."
msgstr ""
"Imposta il numero di canali di uscita ALSA utilizzati da Wine. Disponibile "
"da GE-Proton11-1."

#: src/widgets/games/launch-options-editor/groups/audio-options-group.vala:52
msgid "WINEALSA Spatial Audio"
msgstr "Audio spaziale WINEALSA"

#: src/widgets/games/launch-options-editor/groups/audio-options-group.vala:53
msgid ""
"Enables spatial mixing in Wine ALSA audio output. Requires WINEALSA Channels"
" set to 4, 6, or 8. Available from GE-Proton11-1."
msgstr ""
"Abilita il missaggio spaziale nell'uscita audio ALSA di Wine. Richiede "
"Canali WINEALSA impostati a 4, 6 o 8. Disponibile da GE-Proton11-1."

#: src/widgets/games/launch-options-editor/groups/common-options-group.vala:13
msgid "Common options"
msgstr "Opzioni comuni"

#: src/widgets/games/launch-options-editor/groups/common-options-group.vala:14
msgid "Quick toggles for the launch options people reach for most often."
msgstr "Interruttori rapidi per le opzioni di lancio più utilizzate."

#: src/widgets/games/launch-options-editor/groups/common-options-group.vala:17
msgid "Performance overlay"
msgstr "Overlay delle prestazioni"

#: src/widgets/games/launch-options-editor/groups/common-options-group.vala:18
msgid "Shows an in-game overlay with FPS, CPU/GPU usage, and temps."
msgstr "Mostra un overlay di gioco con FPS, utilizzo CPU/GPU e temperature."

#: src/widgets/games/launch-options-editor/groups/common-options-group.vala:30
msgid "Disable Steam Deck Mode"
msgstr "Disabilita modalità Steam Deck"

#: src/widgets/games/launch-options-editor/groups/common-options-group.vala:30
msgid "Disables the Steam Deck-specific profile that some games use."
msgstr ""
"Disabilita il profilo specifico per Steam Deck che alcuni giochi utilizzano."

#: src/widgets/games/launch-options-editor/groups/common-options-group.vala:32
msgid "Wayland"
msgstr "Wayland"

#: src/widgets/games/launch-options-editor/groups/common-options-group.vala:32
msgid ""
"Runs the game natively on Wayland instead of through XWayland but it breaks "
"Steam Input and the Steam Overlay."
msgstr ""
"Esegue il gioco in modo nativo su Wayland invece che tramite XWayland, ma "
"interrompe Steam Input e Steam Overlay."

#: src/widgets/games/launch-options-editor/groups/common-options-group.vala:34
#: src/widgets/preferences/preferences-dialog.vala:340
msgid "Feral Gamemode"
msgstr "Feral Gamemode"

#: src/widgets/games/launch-options-editor/groups/common-options-group.vala:34
msgid ""
"Requests temporary optimizations for system performance (CPU governor, "
"process priority) when the game is running."
msgstr ""
"Richiede ottimizzazioni temporanee per le prestazioni di sistema (governor "
"CPU, priorità processo) quando il gioco è in esecuzione."

#: src/widgets/games/launch-options-editor/groups/dxvk-options-group.vala:12
msgid "DXVK options"
msgstr "Opzioni DXVK"

#: src/widgets/games/launch-options-editor/groups/dxvk-options-group.vala:13
#: src/widgets/games/launch-options-editor/groups/more-options-group.vala:20
#: src/widgets/games/launch-options-editor/groups/vkd3d-options-group.vala:14
msgid "Extra graphics settings and launch behaviors."
msgstr "Impostazioni grafiche extra e comportamenti di avvio."

#: src/widgets/games/launch-options-editor/groups/dxvk-options-group.vala:16
msgid "DXVK Async"
msgstr "DXVK Async"

#: src/widgets/games/launch-options-editor/groups/dxvk-options-group.vala:17
msgid ""
"Enables DXVK's asynchronous pipeline compilation which can reduce "
"stuttering."
msgstr ""
"Abilita la compilazione asincrona delle pipeline di DXVK, che può ridurre i "
"rallentamenti."

#: src/widgets/games/launch-options-editor/groups/dxvk-options-group.vala:21
msgid "Disable DXVK logging"
msgstr "Disabilita logging DXVK"

#: src/widgets/games/launch-options-editor/groups/dxvk-options-group.vala:22
msgid ""
"Sets DXVK's log level to none which can improve performance in some games."
msgstr ""
"Imposta il livello di log di DXVK su nessuno, migliorando le prestazioni in "
"alcuni giochi."

#: src/widgets/games/launch-options-editor/groups/dxvk-options-group.vala:26
msgid "DXVK Frame Limit"
msgstr "Limite FPS DXVK"

#: src/widgets/games/launch-options-editor/groups/dxvk-options-group.vala:27
msgid "Caps the frame rate using DXVK's built-in frame limiter."
msgstr ""
"Imposta un limite al frame rate utilizzando il limitatore integrato di DXVK."

#: src/widgets/games/launch-options-editor/groups/dxvk-options-group.vala:28
#: src/widgets/games/launch-options-editor/wrappers/gamescope.vala:42
#: src/widgets/games/launch-options-editor/wrappers/scopebuddy.vala:53
msgid "FPS"
msgstr "FPS"

#: src/widgets/games/launch-options-editor/groups/game-arguments-group.vala:14
msgid "Game arguments"
msgstr "Argomenti del gioco"

#: src/widgets/games/launch-options-editor/groups/game-arguments-group.vala:15
msgid "Flags passed directly to the game."
msgstr "Flag passati direttamente al gioco."

#: src/widgets/games/launch-options-editor/groups/game-arguments-group.vala:17
msgid "Skip launcher"
msgstr "Salta launcher"

#: src/widgets/games/launch-options-editor/groups/game-arguments-group.vala:17
msgid "Adds -skip-launcher to bypass launchers in games that support it."
msgstr ""
"Aggiunge -skip-launcher per saltare i launcher nei giochi che lo supportano."

#: src/widgets/games/launch-options-editor/groups/game-arguments-group.vala:18
#: src/widgets/mangohud/mangohud-performance-page.vala:44
msgid "Vulkan"
msgstr "Vulkan"

#: src/widgets/games/launch-options-editor/groups/game-arguments-group.vala:18
msgid "Adds -vulkan to make the game use its Vulkan renderer."
msgstr "Aggiunge -vulkan per far utilizzare al gioco il renderer Vulkan."

#: src/widgets/games/launch-options-editor/groups/game-arguments-group.vala:19
msgid "DirectX 11"
msgstr "DirectX 11"

#: src/widgets/games/launch-options-editor/groups/game-arguments-group.vala:19
msgid "Adds -dx11 to make the game use its DirectX 11 renderer."
msgstr "Aggiunge -dx11 per far utilizzare al gioco il renderer DirectX 11."

#: src/widgets/games/launch-options-editor/groups/game-arguments-group.vala:20
msgid "DirectX 12"
msgstr "DirectX 12"

#: src/widgets/games/launch-options-editor/groups/game-arguments-group.vala:20
msgid "Adds -dx12 to make the game use its DirectX 12 renderer."
msgstr "Aggiunge -dx12 per far utilizzare al gioco il renderer DirectX 12."

#: src/widgets/games/launch-options-editor/groups/game-arguments-group.vala:21
msgid "Console"
msgstr "Console"

#: src/widgets/games/launch-options-editor/groups/game-arguments-group.vala:21
msgid "Adds -console to open the game's developer console when supported."
msgstr ""
"Aggiunge -console per aprire la console di sviluppo del gioco quando "
"supportata."

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-amd-options-group.vala:23
msgid "Mesa Anti-Lag"
msgstr "Mesa Anti-Lag"

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-amd-options-group.vala:23
msgid "Reduces latency on supported AMD Mesa setups."
msgstr "Riduce la latenza su configurazioni AMD Mesa supportate."

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-amd-options-group.vala:24
msgid "Use dGPU"
msgstr "Usa dGPU"

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-amd-options-group.vala:24
msgid "Makes the game use the AMD dGPU on hybrid systems."
msgstr "Fa utilizzare al gioco la dGPU AMD su sistemi ibridi."

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-amd-options-group.vala:25
msgid "Hide AMD APU"
msgstr "Nascondi AMD APU"

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-amd-options-group.vala:25
msgid ""
"Makes Proton report an AMD APU as a discrete GPU for games that mis-detect "
"integrated graphics."
msgstr ""
"Fa sì che Proton segnali una AMD APU come GPU discreta per i giochi che "
"rilevano erroneamente la grafica integrata."

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-amd-options-group.vala:26
msgid "FSR 4 Upgrade"
msgstr "Aggiornamento FSR 4"

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-amd-options-group.vala:26
msgid ""
"Upgrades FSR 3.1 to FSR 4 in supported games. This option also disables AMD "
"Anti-Lag 2 currently due to various issues."
msgstr ""
"Aggiorna FSR 3.1 a FSR 4 nei giochi supportati. Questa opzione disabilita "
"anche AMD Anti-Lag 2 attualmente a causa di vari problemi."

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-amd-options-group.vala:31
msgid "FSR 4 RDNA3 Upgrade"
msgstr "Aggiornamento FSR 4 RDNA3"

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-amd-options-group.vala:31
msgid "Optimizes FSR 4.0 for RDNA3 hardware."
msgstr "Ottimizza FSR 4.0 per hardware RDNA3."

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-amd-options-group.vala:36
msgid "Staging shared memory"
msgstr "Memoria condivisa staging"

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-amd-options-group.vala:36
msgid ""
"Enables shared memory support in the AMD GPU driver for better performance "
"in some games."
msgstr ""
"Abilita il supporto della memoria condivisa nel driver GPU AMD per migliori "
"prestazioni in alcuni giochi."

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-amd-options-group.vala:37
msgid "Mesa GLThread"
msgstr "Mesa GLThread"

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-amd-options-group.vala:37
msgid ""
"Enables Mesa's GLThread optimization for better performance in some games."
msgstr ""
"Abilita l'ottimizzazione GLThread di Mesa per migliori prestazioni in alcuni"
" giochi."

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-amd-options-group.vala:38
msgid "Disable Mesa shader cache"
msgstr "Disabilita cache shader Mesa"

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-amd-options-group.vala:38
msgid "Disables Mesa's shader cache which can cause stuttering in some games."
msgstr ""
"Disabilita la cache shader di Mesa, che può causare rallentamenti in alcuni "
"giochi."

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-amd-options-group.vala:57
msgid ""
"Configure RADV debug options for troubleshooting and performance testing."
msgstr ""
"Configura le opzioni di debug RADV per risoluzione problemi e test delle "
"prestazioni."

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-amd-options-group.vala:58
msgid ""
"Configure RADV performance test options for testing experimental driver "
"features. Use with caution as these features can cause instability or other "
"issues."
msgstr ""
"Configura le opzioni dei test di prestazione RADV per testare funzionalità "
"sperimentali del driver. Usare con cautela poiché queste funzionalità "
"possono causare instabilità o altri problemi."

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-amd-options-group.vala:59
msgid ""
"Select which AMD Vulkan driver to use. This can be used to switch between "
"RADV and AMD's official Vulkan driver on supported systems."
msgstr ""
"Seleziona quale driver Vulkan AMD utilizzare. Può essere usato per passare "
"da RADV al driver Vulkan ufficiale di AMD sui sistemi supportati."

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-amd-options-group.vala:60
msgid ""
"Configure ACO compiler debug options to troubleshoot shader compilation "
"issues, fix in-game stuttering, or analyze graphics performance. Use with "
"caution."
msgstr ""
"Configura le opzioni di debug del compilatore ACO per risolvere problemi di "
"compilazione shader, correggere rallentamenti in-game o analizzare le "
"prestazioni grafiche. Usare con cautela."

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-intel-options-group.vala:10
msgid "XeSS Upgrade"
msgstr "Aggiornamento XeSS"

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-intel-options-group.vala:10
msgid "Upgrades XeSS in supported games."
msgstr "Aggiorna XeSS nei giochi supportati."

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-nvidia-options-group.vala:18
msgid "NVAPI"
msgstr "NVAPI"

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-nvidia-options-group.vala:18
msgid "Lets games access NVIDIA-specific features like DLSS."
msgstr ""
"Consente ai giochi di accedere a funzionalità specifiche NVIDIA come DLSS."

#. gpu_vendor_bindings.append (new LaunchOptionBinding ({
#. "PROTON_ENABLE_NVAPI=1" }, nvapi_tile.toggle));
#: src/widgets/games/launch-options-editor/groups/gpu-vendor-nvidia-options-group.vala:23
msgid "Update DLSS components"
msgstr "Aggiorna componenti DLSS"

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-nvidia-options-group.vala:23
msgid "Auto upgrades DLSS components for supported games."
msgstr "Aggiorna automaticamente i componenti DLSS per i giochi supportati."

#. gpu_vendor_bindings.append (new LaunchOptionBinding ({
#. "PROTON_ENABLE_NGX_UPDATER=1" }, nvidia_ngx_updater_tile.toggle));
#: src/widgets/games/launch-options-editor/groups/gpu-vendor-nvidia-options-group.vala:28
msgid "Hide NVIDIA GPU"
msgstr "Nascondi GPU NVIDIA"

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-nvidia-options-group.vala:28
msgid ""
"Makes Proton report an NVIDIA GPU as AMD for games that expect Windows-only "
"NVIDIA driver behavior."
msgstr ""
"Fa sì che Proton segnali una GPU NVIDIA come AMD per i giochi che si "
"aspettano un comportamento del driver NVIDIA solo Windows."

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-nvidia-options-group.vala:29
msgid "DLSS Indicator"
msgstr "Indicatore DLSS"

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-nvidia-options-group.vala:29
msgid "Shows a DLSS status indicator in-game."
msgstr "Mostra un indicatore dello stato DLSS nel gioco."

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-nvidia-options-group.vala:30
msgid "NVIDIA Libraries"
msgstr "Librerie NVIDIA"

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-nvidia-options-group.vala:30
msgid ""
"Enables NVIDIA-specific libraries (PhysX, CUDA). This is not needed for DLSS"
" or ray tracing."
msgstr ""
"Abilita le librerie specifiche NVIDIA (PhysX, CUDA). Non necessario per DLSS"
" o ray tracing."

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-options-group.vala:23
msgid "GPU vendor options"
msgstr "Opzioni produttore GPU"

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-options-group.vala:27
msgid ""
"Use GPU-specific compatibility toggles for AMD, NVIDIA and Intel hardware."
msgstr ""
"Utilizza interruttori di compatibilità specifici per GPU per hardware AMD, "
"NVIDIA e Intel."

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-options-group.vala:53
msgid "AMD"
msgstr "AMD"

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-options-group.vala:54
msgid "NVIDIA"
msgstr "NVIDIA"

#: src/widgets/games/launch-options-editor/groups/gpu-vendor-options-group.vala:55
msgid "Intel"
msgstr "Intel"

#: src/widgets/games/launch-options-editor/groups/more-options-group.vala:19
msgid "More options"
msgstr "Altre opzioni"

#: src/widgets/games/launch-options-editor/groups/more-options-group.vala:22
msgid "VKBasalt"
msgstr "VKBasalt"

#: src/widgets/games/launch-options-editor/groups/more-options-group.vala:22
msgid "Adds visual effects like sharpening and color adjustments."
msgstr "Aggiunge effetti visivi come nitidezza e regolazioni del colore."

#: src/widgets/games/launch-options-editor/groups/more-options-group.vala:23
msgid "WineD3D"
msgstr "WineD3D"

#: src/widgets/games/launch-options-editor/groups/more-options-group.vala:23
msgid ""
"Uses OpenGL instead of Vulkan. Only enable if you're having DXVK issues."
msgstr ""
"Utilizza OpenGL invece di Vulkan. Abilita solo se hai problemi con DXVK."

#: src/widgets/games/launch-options-editor/groups/more-options-group.vala:24
msgid "Use FSync"
msgstr "Usa FSync"

#: src/widgets/games/launch-options-editor/groups/more-options-group.vala:24
msgid ""
"Uses FSync instead of NTSync. Can fix issues in certain games that do not "
"pair well with NTSync."
msgstr ""
"Utilizza FSync invece di NTSync. Può risolvere problemi in alcuni giochi che"
" non funzionano bene con NTSync."

#: src/widgets/games/launch-options-editor/groups/more-options-group.vala:25
msgid "Local shader cache"
msgstr "Cache shader locale"

#: src/widgets/games/launch-options-editor/groups/more-options-group.vala:25
msgid ""
"Enables per-game shader cache. This isolates the shader cache of each game "
"but does not compile them ahead-of-time."
msgstr ""
"Abilita la cache shader per gioco. Isola la cache shader di ogni gioco ma "
"non le compila in anticipo."

#: src/widgets/games/launch-options-editor/groups/more-options-group.vala:26
msgid "Prefer SDL controller"
msgstr "Preferisci controller SDL"

#: src/widgets/games/launch-options-editor/groups/more-options-group.vala:26
msgid "Workaround for controller detection issues."
msgstr "Soluzione alternativa per problemi di rilevamento del controller."

#: src/widgets/games/launch-options-editor/groups/more-options-group.vala:27
msgid "Disable Steam Input"
msgstr "Disabilita Steam Input"

#: src/widgets/games/launch-options-editor/groups/more-options-group.vala:27
msgid "Disables Steam Input support. Fixes Wayland controller/gamepad issues."
msgstr ""
"Disabilita il supporto Steam Input. Risolve problemi di controller/gamepad "
"su Wayland."

#: src/widgets/games/launch-options-editor/groups/more-options-group.vala:28
msgid "WINE_VK_USE_SYNC2"
msgstr "WINE_VK_USE_SYNC2"

#: src/widgets/games/launch-options-editor/groups/more-options-group.vala:28
msgid ""
"Enables WINE_VK_USE_SYNC2 which can improve performance and reduce "
"stuttering in some games when using WineD3D."
msgstr ""
"Abilita WINE_VK_USE_SYNC2 che può migliorare le prestazioni e ridurre i "
"rallentamenti in alcuni giochi quando si utilizza WineD3D."

#: src/widgets/games/launch-options-editor/groups/more-options-group.vala:29
msgid "WINE_SYNC_USE_FUTEX_WAITV"
msgstr "WINE_SYNC_USE_FUTEX_WAITV"

#: src/widgets/games/launch-options-editor/groups/more-options-group.vala:29
msgid ""
"Enables WINE_SYNC_USE_FUTEX_WAITV which can improve performance and reduce "
"stuttering in some games when using WineD3D."
msgstr ""
"Abilita WINE_SYNC_USE_FUTEX_WAITV che può migliorare le prestazioni e "
"ridurre i rallentamenti in alcuni giochi quando si utilizza WineD3D."

#: src/widgets/games/launch-options-editor/groups/more-options-group.vala:30
msgid "Simulate Write-Copy Memory"
msgstr "Simula memoria Write-Copy"

#: src/widgets/games/launch-options-editor/groups/more-options-group.vala:30
msgid ""
"Forces Wine to simulate page-write protection, fixing initialization errors "
"in certain older titles."
msgstr ""
"Forza Wine a simulare la protezione di scrittura pagina, correggendo errori "
"di inizializzazione in alcuni titoli più vecchi."

#: src/widgets/games/launch-options-editor/groups/proton-options-group.vala:18
msgid "Proton options"
msgstr "Opzioni Proton"

#: src/widgets/games/launch-options-editor/groups/proton-options-group.vala:19
msgid "Extra Proton settings and launch behaviors."
msgstr "Impostazioni Proton extra e comportamenti di avvio."

#: src/widgets/games/launch-options-editor/groups/proton-options-group.vala:21
msgid "Higher priority for games"
msgstr "Priorità più alta per i giochi"

#: src/widgets/games/launch-options-editor/groups/proton-options-group.vala:21
msgid ""
"Gives the game a higher CPU priority which can improve performance in some "
"cases."
msgstr ""
"Assegna al gioco una priorità CPU più alta, che può migliorare le "
"prestazioni in alcuni casi."

#: src/widgets/games/launch-options-editor/groups/proton-options-group.vala:22
msgid "Use WoW64"
msgstr "Usa WoW64"

#: src/widgets/games/launch-options-editor/groups/proton-options-group.vala:22
msgid ""
"Enables WoW64 support for 32-bit games on 64-bit Proton builds. This can "
"improve compatibility for some older games."
msgstr ""
"Abilita il supporto WoW64 per giochi a 32 bit su build Proton a 64 bit. Può "
"migliorare la compatibilità per alcuni giochi più vecchi."

#: src/widgets/games/launch-options-editor/groups/proton-options-group.vala:23
msgid "Allows 32-bit games to use more than 2GB of RAM"
msgstr "Consente ai giochi a 32 bit di utilizzare più di 2 GB di RAM"

#: src/widgets/games/launch-options-editor/groups/proton-options-group.vala:23
msgid ""
"Forces 32-bit games to use large address aware which can improve performance"
" and stability."
msgstr ""
"Forza i giochi a 32 bit a utilizzare large address aware, che può migliorare"
" prestazioni e stabilità."

#: src/widgets/games/launch-options-editor/groups/proton-options-group.vala:24
msgid "Enable Proton logs"
msgstr "Abilita log Proton"

#: src/widgets/games/launch-options-editor/groups/proton-options-group.vala:24
msgid ""
"Enables logging for Proton which can help with troubleshooting game issues. "
"Logs are saved in the game's compatibility data folder."
msgstr ""
"Abilita la registrazione per Proton che può aiutare nella risoluzione dei "
"problemi di gioco. I log vengono salvati nella cartella dei dati di "
"compatibilità del gioco."

#: src/widgets/games/launch-options-editor/groups/proton-options-group.vala:25
msgid "Enable Proton OptiScaler"
msgstr "Abilita Proton OptiScaler"

#: src/widgets/games/launch-options-editor/groups/proton-options-group.vala:25
msgid ""
"Enables the Proton OptiScaler which can improve performance and image "
"quality for some games (Available from version 11-1)."
msgstr ""
"Abilita Proton OptiScaler che può migliorare le prestazioni e la qualità "
"dell'immagine per alcuni giochi (Disponibile dalla versione 11-1)."

#: src/widgets/games/launch-options-editor/groups/proton-options-group.vala:26
msgid "Enable Proton Discord Bridge"
msgstr "Abilita Proton Discord Bridge"

#: src/widgets/games/launch-options-editor/groups/proton-options-group.vala:26
msgid ""
"Enables the Proton Discord Bridge which can improve integration with Discord"
" for some games (Available from version 11-1)."
msgstr ""
"Abilita Proton Discord Bridge che può migliorare l'integrazione con Discord "
"per alcuni giochi (Disponibile dalla versione 11-1)."

#: src/widgets/games/launch-options-editor/groups/proton-options-group.vala:27
msgid "Use D7VK"
msgstr "Usa D7VK"

#: src/widgets/games/launch-options-editor/groups/proton-options-group.vala:27
msgid ""
"Enables the use of D7VK which can improve performance and compatibility for "
"some Direct3D 9 games (Available from version 11-1)."
msgstr ""
"Abilita l'uso di D7VK che può migliorare prestazioni e compatibilità per "
"alcuni giochi Direct3D 9 (Disponibile dalla versione 11-1)."

